            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "row",
      "id": 6,
      "title": "💰 LLM 使用",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "費用趨勢 by model",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (openclaw_model)(rate(openclaw_cost_usd_total[10m]))*3600",
          "legendFormat": "{{openclaw_model}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "gradientMode": "opacity"
          },
          "unit": "currencyUSD"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "piechart",
      "id": 8,
      "title": "費用分佈",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (openclaw_model)(increase(openclaw_cost_usd_total[1d]))",
          "legendFormat": "{{openclaw_model}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "pie"
      }
    },
    {
      "type": "bargauge",
      "id": 9,
      "title": "Input/Output Tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (openclaw_model,openclaw_token)(increase(openclaw_tokens_total{openclaw_token=~\"input|output\"}[1d]))",
          "legendFormat": "{{openclaw_model}}-{{openclaw_token}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
